Options -Indexes
Options FollowSymLinks

# Enable URL rewriting
RewriteEngine On

# Block access to sensitive files (env, logs, sql, shell scripts, markdown)
<FilesMatch "\.(env|log|sql|sh|bat|md|gitignore|bak|backup)$">
    Require all denied
</FilesMatch>

# Block direct access to sensitive PHP includes
<FilesMatch "^(env_loader|error_handler|security|security_headers|session_config|auth)\.php$">
    Require all denied
</FilesMatch>

# Block direct access to protected directories
RewriteRule ^(includes|database|logs|scanner_service)(/|$) - [F,L]

# PHP runtime settings — increase limits for PDF uploads
# (These work on both XAMPP and Synology Apache with PHP module)
<IfModule mod_php.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 25M
    php_value max_execution_time 120
    php_value memory_limit 256M
    php_value session.gc_maxlifetime 3600
    php_value session.cookie_httponly 1
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 25M
    php_value max_execution_time 120
    php_value memory_limit 256M
    php_value session.gc_maxlifetime 3600
    php_value session.cookie_httponly 1
</IfModule>

# Redirect bare root to login
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^$ public/login.php [L,R=302]

# Set default character set
AddDefaultCharset UTF-8
