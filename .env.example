# Environment Configuration
# Copy this file to .env and update with your actual values

# Application Environment
APP_ENV=development
# Options: development, production
# - development: Shows detailed errors, disables some security features for localhost
# - production: Hides errors, enforces HTTPS, stricter security

# Database Configuration
DB_HOST=localhost
DB_NAME=iscan_db
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME=Civil Registry Records Management System
APP_SHORT_NAME=iSCAN
APP_VERSION=1.0.0
BASE_URL=/iscan/

# Security Settings
SESSION_TIMEOUT=3600
# Session timeout in seconds (3600 = 1 hour)

ENABLE_CSRF_PROTECTION=true
# Enable CSRF token validation

ENABLE_RATE_LIMITING=true
# Enable rate limiting for login and sensitive endpoints

MAX_LOGIN_ATTEMPTS=5
# Maximum login attempts before lockout

RATE_LIMIT_WINDOW=300
# Rate limit time window in seconds (300 = 5 minutes)

ACCOUNT_LOCKOUT_DURATION=900
# Account lockout duration in seconds (900 = 15 minutes)

# Password Policy
MIN_PASSWORD_LENGTH=8
# Minimum password length

REQUIRE_PASSWORD_COMPLEXITY=false
# Require uppercase, lowercase, numbers, and special characters

PASSWORD_EXPIRY_DAYS=90
# Days before password expires (0 = never)

# File Upload Settings
MAX_FILE_SIZE=5242880
# Maximum file upload size in bytes (5242880 = 5MB)

ALLOWED_FILE_TYPES=pdf
# Comma-separated list of allowed file extensions

# Logging
ENABLE_ERROR_LOGGING=true
ENABLE_SECURITY_LOGGING=true
ENABLE_ACTIVITY_LOGGING=true

LOG_ROTATION_SIZE=10485760
# Log file size before rotation in bytes (10485760 = 10MB)

# Email Notifications (optional)
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Security Headers
ENABLE_HSTS=true
# Enable HTTP Strict Transport Security (HTTPS only)

ENABLE_CSP=true
# Enable Content Security Policy

# Timezone
TIMEZONE=Asia/Manila
