# ================================================================
# iScan - Synology NAS Environment Configuration
# ================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env:   cp .env.synology .env
#   2. Edit .env with your actual database credentials
#   3. Run: sudo bash setup_synology.sh
# ================================================================

APP_ENV=production
APP_NAME=Civil Registry Records Management System
APP_SHORT_NAME=iSCAN
APP_VERSION=1.0.0

# ----------------------------------------------------------------
# Database — Synology MariaDB 10 (install via Package Center)
# Create a dedicated user instead of using root:
#   CREATE USER 'iscan_user'@'localhost' IDENTIFIED BY 'your_password';
#   GRANT ALL PRIVILEGES ON iscan_db.* TO 'iscan_user'@'localhost';
#   FLUSH PRIVILEGES;
# ----------------------------------------------------------------
DB_HOST=localhost
DB_NAME=iscan_db
DB_USER=iscan_user
DB_PASS=CHANGE_THIS_PASSWORD

# ----------------------------------------------------------------
# Base URL
#   /        — if this is the root virtual host (Cloudflare tunnel, Web Station VirtualHost)
#   /iscan/  — if accessed via http://192.168.x.x/iscan/ (no VirtualHost, shared webroot)
# ----------------------------------------------------------------
BASE_URL=/

# Timezone
TIMEZONE=Asia/Manila

# ----------------------------------------------------------------
# Security Settings
# ----------------------------------------------------------------
SESSION_TIMEOUT=3600
ENABLE_CSRF_PROTECTION=true
ENABLE_RATE_LIMITING=true
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW=300
ACCOUNT_LOCKOUT_DURATION=900

# Password Policy
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_COMPLEXITY=true
PASSWORD_EXPIRY_DAYS=90

# ----------------------------------------------------------------
# File Uploads (20MB for large PDF scans)
# ----------------------------------------------------------------
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=pdf

# ----------------------------------------------------------------
# Logging
# ----------------------------------------------------------------
ENABLE_ERROR_LOGGING=true
ENABLE_SECURITY_LOGGING=true
ENABLE_ACTIVITY_LOGGING=true
LOG_ROTATION_SIZE=10485760

# ----------------------------------------------------------------
# Security Headers
# Set ENABLE_HSTS=true only if using HTTPS (SSL certificate)
# Leave false for plain HTTP on LAN
# ----------------------------------------------------------------
ENABLE_HSTS=true
ENABLE_CSP=true

# ----------------------------------------------------------------
# Offline Mode
# true  = use locally downloaded vendor assets (works without internet)
# false = use CDN links (requires internet, loads faster first time)
# Recommended: true for NAS/LAN deployment
# ----------------------------------------------------------------
OFFLINE_MODE=true

# ----------------------------------------------------------------
# Device Lock Security
# Recommended: true for production NAS deployment
# IMPORTANT: Register all office devices in Admin > Devices FIRST,
#            then set this to true. Setting to true before registering
#            any device will block everyone including the admin!
# ----------------------------------------------------------------
ENABLE_DEVICE_LOCK=false

# ----------------------------------------------------------------
# RA 9048/10172 Module Toggle
# ----------------------------------------------------------------
# false = sidebar hidden, public pages return 403, APIs return 503 (paused)
# true  = full RA 9048 module active
# See docs/RA9048_FEATURE_TOGGLE.md for the full re-enable procedure.
# ----------------------------------------------------------------
RA9048_FEATURE_ENABLED=false

# ----------------------------------------------------------------
# LibreOffice (for DOCX → PDF conversion of generated RA 9048 documents)
# Synology options:
#   1. Docker image (recommended on DSM 7+):
#        LIBREOFFICE_PATH=docker:iscan-libreoffice
#      (Build the image with the Dockerfile in docs/NAS_LIBREOFFICE_DOCKER.md)
#   2. SynoCommunity LibreOffice (if available for your DSM/CPU):
#        LIBREOFFICE_PATH=/var/packages/libreoffice/target/usr/bin/soffice
#   3. Leave blank to disable auto-PDF (system still generates .docx normally)
# ----------------------------------------------------------------
LIBREOFFICE_PATH=docker:iscan-libreoffice
